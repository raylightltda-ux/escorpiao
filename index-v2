<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Monitor Escorpiões Brasil 🦂 - Dashboard</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
    <style>
        *{margin:0;padding:0;box-sizing:border-box}
        body{background:linear-gradient(135deg, #0f172a 0%, #1e293b 100%);color:#e2e8f0;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;padding:12px;min-height:100vh}
        .container{max-width:1400px;margin:0 auto}
        .header{text-align:center;margin-bottom:25px}
        .header h1{display:flex;align-items:center;justify-content:center;gap:10px;font-size:1.8rem;margin-bottom:12px}
        .info-box{background:rgba(59,130,246,.15);border:1px solid rgba(59,130,246,.3);border-radius:8px;padding:12px;margin-bottom:12px;font-size:.95rem}
        .info-box strong{color:#60a5fa}
        .schedule-info{background:rgba(34,197,94,.15);border:1px solid rgba(34,197,94,.3);border-radius:8px;padding:10px;font-size:.85rem;color:#86efac;margin-bottom:12px}
        .buttons{display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap;justify-content:center}
        button{display:flex;align-items:center;gap:6px;padding:10px 16px;border:none;border-radius:8px;font-size:.9rem;font-weight:bold;cursor:pointer;transition:all .3s ease}
        .btn-refresh{background:linear-gradient(135deg, #f59e0b, #dc2626);color:white}
        .btn-refresh:hover{opacity:0.9}
        .btn-csv{background:#1e40af;color:white}
        .btn-csv:hover{background:#1e3a8a}
        .btn-whatsapp{background:#25d366;color:white}
        .btn-whatsapp:hover{background:#20ba5a}
        
        .dashboard{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:20px;margin-bottom:30px}
        .card{background:rgba(15,23,42,.6);border:1px solid rgba(148,163,184,.2);border-radius:10px;padding:20px}
        .card-title{font-size:1rem;color:#60a5fa;margin-bottom:15px;font-weight:bold}
        .card-number{font-size:2.5rem;font-weight:bold;color:#fbbf24;margin-bottom:5px}
        .card-sub{font-size:.85rem;color:#94a3b8}
        
        .top-states{display:grid;gap:10px}
        .state-item{display:flex;justify-content:space-between;align-items:center;padding:10px;background:rgba(255,255,255,.05);border-radius:6px;border-left:4px solid #f59e0b}
        .state-name{font-weight:bold}
        .state-count{color:#fbbf24;font-weight:bold}
        
        .chart-container{background:rgba(15,23,42,.6);border:1px solid rgba(148,163,184,.2);border-radius:10px;padding:20px;margin-bottom:20px}
        .chart-title{font-size:1.1rem;color:#60a5fa;margin-bottom:15px;font-weight:bold}
        
        .mapa-calor{background:rgba(15,23,42,.6);border:1px solid rgba(148,163,184,.2);border-radius:10px;padding:20px;margin-bottom:20px}
        .mapa-titulo{font-size:1.1rem;color:#60a5fa;margin-bottom:15px;font-weight:bold}
        .mapa-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:10px}
        .estado-box{padding:15px;border-radius:8px;text-align:center;transition:all .3s ease;cursor:pointer}
        .estado-box:hover{transform:scale(1.05)}
        .estado-sigla{font-weight:bold;font-size:1.1rem;margin-bottom:5px}
        .estado-count{font-size:.85rem;color:#000}
        
        .tabela-section{background:rgba(15,23,42,.6);border:1px solid rgba(148,163,184,.2);border-radius:10px;padding:20px;margin-bottom:20px}
        .tabela-titulo{font-size:1.1rem;color:#60a5fa;margin-bottom:15px;font-weight:bold}
        .filtro{margin-bottom:15px}
        .filtro select{background:rgba(59,130,246,.2);border:1px solid rgba(59,130,246,.3);border-radius:6px;padding:8px 12px;color:#e2e8f0;font-size:.9rem}
        .filtro select option{background:#1e293b;color:#e2e8f0}
        
        table{width:100%;border-collapse:collapse}
        th{padding:12px;text-align:left;border-bottom:2px solid rgba(148,163,184,.2);background:rgba(59,130,246,.1);font-size:.9rem;color:#60a5fa}
        td{padding:12px;border-bottom:1px solid rgba(148,163,184,.1);font-size:.85rem}
        tr:hover{background:rgba(59,130,246,.05)}
        
        .loading{text-align:center;padding:30px;color:#94a3b8}
        .spinner{border:4px solid rgba(59,130,246,.2);border-top:4px solid #60a5fa;border-radius:50%;width:40px;height:40px;animation:spin 1s linear infinite;margin:20px auto}
        @keyframes spin{0%{transform:rotate(0)}100%{transform:rotate(360deg)}}
        
        @media(max-width:640px){
            .header h1{font-size:1.4rem}
            .dashboard{grid-template-columns:1fr}
            .chart-container{padding:15px}
            .mapa-grid{grid-template-columns:repeat(auto-fill,minmax(100px,1fr))}
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🦂 Monitor Escorpiões Brasil - Dashboard</h1>
            <div class="info-box">
                <div><strong>📊 Total de notícias:</strong> <span id="totalNoticias">Carregando...</span></div>
                <div id="lastUpdate" style="font-size:.8rem;color:#94a3b8;margin-top:4px;"></div>
            </div>
            <div class="schedule-info">
                ✅ Dados atualizados automaticamente - Dashboard em tempo real
            </div>
        </div>

        <div class="buttons">
            <button class="btn-refresh" onclick="location.reload()">🔄 Recarregar</button>
            <button class="btn-csv" onclick="exportarCSV()">📥 Exportar CSV</button>
            <button class="btn-whatsapp" onclick="compartilharWhatsApp()">💬 Compartilhar</button>
        </div>

        <!-- CARDS DE RESUMO -->
        <div class="dashboard">
            <div class="card">
                <div class="card-title">📊 Total de Notícias</div>
                <div class="card-number" id="cardTotal">0</div>
                <div class="card-sub">Últimos 30 dias</div>
            </div>
            <div class="card">
                <div class="card-title">🗺️ Estados Afetados</div>
                <div class="card-number" id="cardEstados">0</div>
                <div class="card-sub">Regiões com casos</div>
            </div>
            <div class="card">
                <div class="card-title">🔴 Casos Graves</div>
                <div class="card-number" id="cardGraves">0</div>
                <div class="card-sub">Alertas críticos</div>
            </div>
            <div class="card">
                <div class="card-title">📈 Crescimento</div>
                <div class="card-number" id="cardCrescimento">+0%</div>
                <div class="card-sub">vs período anterior</div>
            </div>
        </div>

        <!-- TOP 5 ESTADOS -->
        <div class="card" style="margin-bottom:20px">
            <div class="card-title">🏆 Top 5 Estados Mais Afetados</div>
            <div class="top-states" id="topStates">
                <div class="loading"><div class="spinner"></div></div>
            </div>
        </div>

        <!-- MAPA DE CALOR -->
        <div class="mapa-calor">
            <div class="mapa-titulo">🔥 Mapa de Calor - Intensidade por Estado</div>
            <div class="mapa-grid" id="mapaCalor">
                <div class="loading"><div class="spinner"></div></div>
            </div>
        </div>

        <!-- GRÁFICO DE TENDÊNCIA -->
        <div class="chart-container">
            <div class="chart-title">📈 Tendência de Casos - Últimos 30 Dias</div>
            <canvas id="graficoTendencia"></canvas>
        </div>

        <!-- TABELA DE CIDADES -->
        <div class="tabela-section">
            <div class="tabela-titulo">🏙️ Detalhes por Cidade</div>
            <div class="filtro">
                <select id="filtroEstado" onchange="atualizarTabela()">
                    <option value="">Todos os Estados</option>
                </select>
            </div>
            <div style="overflow-x:auto">
                <table>
                    <thead>
                        <tr>
                            <th>Cidade</th>
                            <th>Estado</th>
                            <th>Notícias</th>
                            <th>Gravidade</th>
                            <th>Última Notícia</th>
                        </tr>
                    </thead>
                    <tbody id="tabelaCidades">
                        <tr><td colspan="5" style="text-align:center">Carregando...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
    <script>
        let allNoticias = [];
        let graficoTendencia = null;

        document.addEventListener('DOMContentLoaded', carregarDados);

        async function carregarDados() {
            try {
                const response = await fetch('noticias.json');
                if (!response.ok) throw new Error('Arquivo não encontrado');
                
                allNoticias = await response.json();
                console.log(`✅ ${allNoticias.length} notícias carregadas`);
                
                atualizarDashboard();
            } catch (e) {
                console.error('Erro:', e);
                document.getElementById('cardTotal').textContent = 'Erro';
            }
        }

        function atualizarDashboard() {
            const agora = new Date();
            const trintaDiasAtras = new Date(agora.getTime() - 30 * 24 * 60 * 60 * 1000);
            
            const noticiasUltimosMeses = allNoticias.filter(n => {
                const data = new Date(n.data.split('/').reverse().join('-'));
                return data >= trintaDiasAtras;
            });

            document.getElementById('totalNoticias').textContent = allNoticias.length;
            document.getElementById('lastUpdate').textContent = '📅 ' + new Date().toLocaleString('pt-BR');
            document.getElementById('cardTotal').textContent = noticiasUltimosMeses.length;

            // Calcular dados por estado
            const porEstado = {};
            allNoticias.forEach(n => {
                const estado = n.estado || 'Nacional';
                if (!porEstado[estado]) {
                    porEstado[estado] = { total: 0, grave: 0, cidades: new Set(), ultimas: [] };
                }
                porEstado[estado].total++;
                if (n.gravidade === 'grave') porEstado[estado].grave++;
                if (n.cidade) porEstado[estado].cidades.add(n.cidade);
                porEstado[estado].ultimas.push(n);
            });

            document.getElementById('cardEstados').textContent = Object.keys(porEstado).length;
            const totalGraves = Object.values(porEstado).reduce((sum, e) => sum + e.grave, 0);
            document.getElementById('cardGraves').textContent = totalGraves;

            // Calcular crescimento
            const noticiasAnterior = allNoticias.filter(n => {
                const data = new Date(n.data.split('/').reverse().join('-'));
                return data >= new Date(agora.getTime() - 60 * 24 * 60 * 60 * 1000) && 
                       data < trintaDiasAtras;
            });
            const crescimento = noticiasAnterior.length > 0 
                ? Math.round(((noticiasUltimosMeses.length - noticiasAnterior.length) / noticiasAnterior.length) * 100)
                : 0;
            document.getElementById('cardCrescimento').textContent = (crescimento > 0 ? '+' : '') + crescimento + '%';

            // Top 5 Estados
            const top5 = Object.entries(porEstado)
                .sort((a, b) => b[1].total - a[1].total)
                .slice(0, 5);

            let topHtml = '';
            top5.forEach(([estado, dados]) => {
                topHtml += `
                    <div class="state-item">
                        <span class="state-name">${estado}</span>
                        <span class="state-count">${dados.total} notícias</span>
                    </div>
                `;
            });
            document.getElementById('topStates').innerHTML = topHtml;

            // Mapa de Calor
            const cores = ['#10b981', '#86efac', '#fbbf24', '#fb923c', '#f87171', '#ef4444'];
            const max = Math.max(...top5.map(e => e[1].total));
            
            let mapaHtml = '';
            Object.entries(porEstado)
                .sort((a, b) => b[1].total - a[1].total)
                .forEach(([estado, dados]) => {
                    const intensidade = dados.total / max;
                    const corIndex = Math.min(5, Math.floor(intensidade * 6));
                    const cor = cores[corIndex];
                    
                    mapaHtml += `
                        <div class="estado-box" style="background-color:${cor};opacity:${0.5 + intensidade * 0.5};" 
                             title="${estado}: ${dados.total} notícias">
                            <div class="estado-sigla">${estado.substring(0, 2)}</div>
                            <div class="estado-count">${dados.total}</div>
                        </div>
                    `;
                });
            document.getElementById('mapaCalor').innerHTML = mapaHtml;

            // Gráfico de Tendência
            gerarGraficoTendencia(allNoticias);

            // Filtro de Estados
            let filtroHtml = '<option value="">Todos os Estados</option>';
            Object.keys(porEstado).sort().forEach(estado => {
                filtroHtml += `<option value="${estado}">${estado}</option>`;
            });
            document.getElementById('filtroEstado').innerHTML = filtroHtml;

            atualizarTabela();
        }

        function gerarGraficoTendencia(noticias) {
            const dias30 = {};
            const hoje = new Date();
            
            for (let i = 29; i >= 0; i--) {
                const data = new Date(hoje.getTime() - i * 24 * 60 * 60 * 1000);
                const chave = data.toLocaleDateString('pt-BR');
                dias30[chave] = 0;
            }

            noticias.forEach(n => {
                const chave = n.data;
                if (dias30.hasOwnProperty(chave)) {
                    dias30[chave]++;
                }
            });

            const ctx = document.getElementById('graficoTendencia').getContext('2d');
            
            if (graficoTendencia) graficoTendencia.destroy();
            
            graficoTendencia = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: Object.keys(dias30),
                    datasets: [{
                        label: 'Notícias por dia',
                        data: Object.values(dias30),
                        borderColor: '#f59e0b',
                        backgroundColor: 'rgba(245, 158, 11, 0.1)',
                        borderWidth: 2,
                        fill: true,
                        tension: 0.4,
                        pointRadius: 4,
                        pointBackgroundColor: '#f59e0b',
                        pointHoverRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            labels: { color: '#e2e8f0' }
                        }
                    },
                    scales: {
                        y: {
                            ticks: { color: '#94a3b8' },
                            grid: { color: 'rgba(148, 163, 184, 0.1)' }
                        },
                        x: {
                            ticks: { color: '#94a3b8' },
                            grid: { color: 'rgba(148, 163, 184, 0.1)' }
                        }
                    }
                }
            });
        }

        function atualizarTabela() {
            const filtroEstado = document.getElementById('filtroEstado').value;
            
            const porCidade = {};
            allNoticias
                .filter(n => !filtroEstado || n.estado === filtroEstado)
                .forEach(n => {
                    const chave = `${n.cidade}, ${n.estado}`;
                    if (!porCidade[chave]) {
                        porCidade[chave] = { 
                            total: 0, 
                            grave: 0, 
                            ultima: n.data,
                            estado: n.estado 
                        };
                    }
                    porCidade[chave].total++;
                    if (n.gravidade === 'grave') porCidade[chave].grave++;
                    porCidade[chave].ultima = n.data;
                });

            let html = '';
            Object.entries(porCidade)
                .sort((a, b) => b[1].total - a[1].total)
                .forEach(([cidade, dados]) => {
                    const gravidade = dados.grave > 0 ? '🔴 Grave' : (dados.total > 5 ? '🟡 Moderado' : '🟢 Leve');
                    html += `
                        <tr>
                            <td>${cidade.split(',')[0]}</td>
                            <td>${dados.estado}</td>
                            <td><strong>${dados.total}</strong></td>
                            <td>${gravidade}</td>
                            <td>${dados.ultima}</td>
                        </tr>
                    `;
                });

            document.getElementById('tabelaCidades').innerHTML = html || '<tr><td colspan="5" style="text-align:center">Nenhum resultado</td></tr>';
        }

        function exportarCSV() {
            let csv = 'Data,Cidade,Estado,Tipo,Gravidade,Título,Fonte,Link\n';
            allNoticias.forEach(n => {
                csv += `"${n.data}","${n.cidade || 'Brasil'}","${n.estado || 'Nacional'}","${n.tipo || 'alerta'}","${n.gravidade}","${n.titulo}","${n.fonte}","${n.link}"\n`;
            });
            
            const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement('a');
            const url = URL.createObjectURL(blob);
            link.setAttribute('href', url);
            link.setAttribute('download', `escorpioes-dashboard-${new Date().toISOString().split('T')[0]}.csv`);
            link.style.visibility = 'hidden';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }

        function compartilharWhatsApp() {
            const url = window.location.href;
            const msg = `🦂 Dashboard Escorpiões Brasil\n\n📊 ${allNoticias.length} notícias REAIS\n📈 Com análises de tendência e mapa de calor\n\n🔗 Acesse: ${url}`;
            const waUrl = `https://wa.me/?text=${encodeURIComponent(msg)}`;
            window.open(waUrl, '_blank');
        }
    </script>
</body>
</html>
